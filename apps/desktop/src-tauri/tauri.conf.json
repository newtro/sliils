{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SliilS",
  "version": "0.0.0",
  "identifier": "com.sliils.app",
  "build": {
    "beforeDevCommand": "pnpm --filter @sliils/web dev",
    "beforeBuildCommand": "pnpm --filter @sliils/web build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "SliilS",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "copyright": "© 2026 SliilS contributors",
    "shortDescription": "Self-hosted team collaboration",
    "longDescription": "SliilS — self-hosted, multi-tenant team collaboration platform. Slack/Teams alternative with no per-seat tax.",
    "icon": [
      "icons/icon.png"
    ]
  }
}
