# Copy this file to .env for local development.
# .env is gitignored.

# ---- HTTP server ----
SLIILS_LISTEN_ADDR=:8080
SLIILS_LOG_LEVEL=info
SLIILS_LOG_FORMAT=text
SLIILS_READ_TIMEOUT=15s
SLIILS_WRITE_TIMEOUT=30s

# ---- Postgres ----
# Replace password with your local Postgres password. Run migrations
# automatically on startup by leaving SLIILS_AUTO_MIGRATE unset (it defaults
# to true). One-time setup:
#   createdb -U postgres sliils_dev
#   psql -U postgres -d sliils_dev -c "CREATE EXTENSION citext;"
SLIILS_DATABASE_URL=postgres://postgres:REPLACE_ME@localhost:5432/sliils_dev?sslmode=disable
SLIILS_AUTO_MIGRATE=true

# ---- Auth ----
# Generate a fresh signing key for your install:
#   openssl rand -hex 32
# Must be at least 32 characters.
SLIILS_JWT_SIGNING_KEY=REPLACE_ME_WITH_openssl_rand_hex_32
SLIILS_ACCESS_TOKEN_TTL=15m
SLIILS_REFRESH_TOKEN_TTL=720h
SLIILS_EMAIL_VERIFY_TTL=24h
SLIILS_PASSWORD_RESET_TTL=1h
SLIILS_MAGIC_LINK_TTL=15m

# Where the web client lives. Used to build links inside emails and as a
# CORS origin. For Docker Compose deployments this is your public HTTPS URL.
SLIILS_PUBLIC_BASE_URL=http://localhost:5173

# Cookie behavior. Keep Secure=false for plain-HTTP local dev; set to true in
# production so the refresh cookie is only sent over HTTPS.
SLIILS_COOKIE_SECURE=false
SLIILS_COOKIE_SAMESITE=lax
# SLIILS_COOKIE_DOMAIN=example.com

# Brute-force lockout
SLIILS_MAX_FAILED_LOGINS=10
SLIILS_LOGIN_LOCKOUT_MINUTES=15

# ---- Email (Resend) ----
# Paid Resend account: https://resend.com/api-keys
SLIILS_RESEND_API_KEY=REPLACE_ME
# Until you verify a domain at resend.com/domains, keep this as
# onboarding@resend.dev — Resend will only deliver to the email address that
# owns the API key. Change to noreply@yourdomain.com after verification.
SLIILS_EMAIL_FROM=onboarding@resend.dev
SLIILS_EMAIL_FROM_NAME=SliilS

# ---- Storage (M5) ----
# Backend: "local" (default) writes to SLIILS_STORAGE_ROOT on disk.
# "s3" slots in once the SeaweedFS/S3-compatible driver lands.
SLIILS_STORAGE_BACKEND=local
SLIILS_STORAGE_ROOT=./data/files

# ---- Calls (M8 — LiveKit) ----
# Install LiveKit locally (Windows binary lives at
# C:\Users\scott\tools\livekit\livekit-server.exe per the dev setup docs;
# download from github.com/livekit/livekit/releases). Start with:
#   livekit-server --config <path>/config/livekit-dev.yaml
# The key/secret MUST match the `keys:` block in livekit-dev.yaml so the
# HMAC-signed join tokens this app issues validate on the LiveKit side.
SLIILS_CALLS_ENABLED=true
SLIILS_LIVEKIT_URL=http://127.0.0.1:7880
SLIILS_LIVEKIT_WS_URL=ws://127.0.0.1:7880
SLIILS_LIVEKIT_API_KEY=devkey
SLIILS_LIVEKIT_API_SECRET=REPLACE_ME_WITH_openssl_rand_hex_32
SLIILS_CALL_JOIN_TOKEN_TTL=2h

# ---- Search (M6 — Meilisearch) ----
# Start Meilisearch locally for dev:
#   docker run -d --name sliils-meili -p 7700:7700 \
#     -e MEILI_MASTER_KEY=local-dev-master-key-change-in-prod \
#     -v $PWD/data/meili:/meili_data getmeili/meilisearch:v1.12
# Then point SLIILS_MEILI_MASTER_KEY at the same value. The master key is
# server-side only; clients receive short-lived HMAC-scoped tenant tokens.
SLIILS_SEARCH_ENABLED=true
SLIILS_MEILI_URL=http://localhost:7700
SLIILS_MEILI_MASTER_KEY=REPLACE_ME_WITH_openssl_rand_hex_32
# Prefix so multiple installs can share a Meili instance (dev, test, prod).
SLIILS_SEARCH_INDEX_PREFIX=sliils
# Outbox drain cadence. 2s is well under the 60s delete-purge SLO.
SLIILS_SEARCH_DRAIN_PERIOD=2s
# TTL for per-session tenant tokens issued to clients.
SLIILS_SEARCH_TOKEN_TTL=15m
