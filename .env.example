# SliilS environment — copy to .env (which is gitignored) before running docker compose.

# Application
SLIILS_VERSION=dev
SLIILS_LOG_LEVEL=info

# Domain (leave blank for localhost-only HTTP; set for Caddy auto-TLS)
# SLIILS_DOMAIN=sliils.example.com

# Postgres
POSTGRES_PASSWORD=change-me-in-production

# Meilisearch master key (must be 32+ chars in production)
# Generate: openssl rand -hex 32
MEILI_MASTER_KEY=dev-meili-master-key-change-me
